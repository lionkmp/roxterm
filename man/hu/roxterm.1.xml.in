      <command>&dhpackage;</command>
      <arg><option>-?</option> | <option>--help</option></arg>
      <arg><option>--help-all</option></arg>
      <arg><option>--help-gtk</option></arg>
      <arg><option>-u</option> | <option>--usage</option></arg>
      <arg><option>--geometry=<replaceable>GEOM</replaceable></option>
        | <option>-g <replaceable>GEOM</replaceable></option></arg>
      <arg><option>--appdir=<replaceable>KÖNYVTÁR</replaceable></option></arg>
      <arg><option>--profile=<replaceable>PROFIL</replaceable></option> |
        <option>-p <replaceable>PROFIL</replaceable></option></arg>
      <arg><option>--colour-scheme=<replaceable>SÉMA</replaceable></option> |
        <option>--color-scheme=<replaceable>SÉMA</replaceable></option> |
        <option>-c <replaceable>SÉMA</replaceable></option></arg>
      <arg><option>--shortcut-scheme=<replaceable>SÉMA</replaceable></option>
        | <option>-s <replaceable>SÉMA</replaceable></option></arg>
      <arg><option>--separate</option></arg>
      <arg><option>--replace</option></arg>
      <arg><option>--fork</option></arg>
      <arg><option>--hold</option></arg>
      <arg><option>--atexit=<replaceable>MŰVELET</replaceable></option></arg>
      <arg><option>--directory=<replaceable>KÖNYVTÁR</replaceable></option> |
        <option>-d <replaceable>KÖNYVTÁR</replaceable></option></arg>
      <arg><option>--show-menubar</option></arg>
      <arg><option>--hide-menubar</option></arg>
      <arg><option>--maximise</option> | <option>-m</option></arg>
      <arg><option>--fullscreen</option> | <option>-f</option></arg>
      <arg><option>--borderless</option> | <option>-b</option></arg>
      <arg><option>--disable-sm</option></arg>
      <arg><option>--tab</option></arg>
      <arg><option>--zoom=<replaceable>NAGYÍTÁS</replaceable></option> |
        <option>-z <replaceable>NAGYÍTÁS</replaceable></option></arg>
      <arg><option>--title=<replaceable>CÍM</replaceable></option> |
        <option>-T <replaceable>CÍM</replaceable></option></arg>
      <arg><option>--tab-name=<replaceable>NÉV</replaceable></option> |
        <option>-n <replaceable>NÉV</replaceable></option></arg>
      <arg><option>--role=<replaceable>SZEREP</replaceable></option></arg>
      <arg><option>--session=<replaceable>MUNKAMENET</replaceable></option></arg>
      <arg><option>--display=<replaceable>KIJELZŐ</replaceable></option></arg>
